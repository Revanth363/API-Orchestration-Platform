# Server
PORT=5000
LOG_LEVEL=info

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Redis cache
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Gemini
GEMINI_API_KEY=

# Node Environment
NODE_ENV=development